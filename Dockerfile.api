FROM python:3.10-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

COPY configs/ configs/
COPY src/ src/

# Trained models and processed data are mounted at runtime via volume
# docker run --rm -p 8000:8000 -v $(pwd)/outputs:/app/outputs secpipeai-api
VOLUME ["/app/outputs", "/app/data/processed"]

EXPOSE 8000

CMD ["uvicorn", "src.api.inference:app", "--host", "0.0.0.0", "--port", "8000"]
